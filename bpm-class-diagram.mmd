    %% ─── bambuprinter ───────────────────────────────────────────────
    class BambuPrinter {
        -BambuConfig _config
        -BambuState _printer_state
        -ActiveJobInfo _active_job_info
        -ServiceState _service_state
        +start_session()
        +pause_session()
        +resume_session()
        +quit()
        +refresh()
        +set_bed_temp_target(value)
        +set_nozzle_temp_target(value, tool_num)
        +set_chamber_temp(value)
        +set_chamber_temp_target(value, temper_check)
        +set_part_cooling_fan_speed_target_percent(value)
        +set_aux_fan_speed_target_percent(value)
        +set_exhaust_fan_speed_target_percent(value)
        +unload_filament(ams_id)
        +load_filament(slot_id, ams_id)
        +send_gcode(gcode)
        +print_3mf_file(...)
        +stop_printing()
        +pause_printing()
        +resume_printing()
        +get_sdcard_3mf_files()
        +get_sdcard_contents()
        +delete_sdcard_file(file)
        +delete_sdcard_folder(path)
        +upload_sdcard_file(src, dest)
        +download_sdcard_file(src, dest)
        +make_sdcard_directory(dir)
        +rename_sdcard_file(src, dest)
        +sdcard_file_exists(path)
        +set_print_option(option, enabled)
        +set_ams_user_setting(...)
        +set_spool_k_factor(...)
        +set_spool_details(...)
        +send_ams_control_command(cmd)
        +skip_objects(objects)
        +set_buildplate_marker_detector(enabled)
        +set_spaghetti_detector(enabled, sensitivity)
        +set_purgechutepileup_detector(enabled, sensitivity)
        +set_nozzleclumping_detector(enabled, sensitivity)
        +set_airprinting_detector(enabled, sensitivity)
        +set_nozzle_details(...)
        +refresh_nozzles()
        +send_anything(anything)
        +turn_on_ams_dryer(...)
        +turn_off_ams_dryer(ams_id)
        +set_active_tool(id)
        +refresh_spool_rfid(slot_id, ams_id)
        +get_current_bind_list(state)
        +select_extrusion_calibration_profile(tray_id, cali_idx)
        +toJson()
        +config() BambuConfig
        +service_state() ServiceState
        +printer_state() BambuState
        +active_job_info() ActiveJobInfo
        +light_state() bool
        +speed_level() str
        +nozzle_diameter() NozzleDiameter
        +nozzle_type() NozzleType
        +recent_update() bool
        +cached_sd_card_contents()
        +cached_sd_card_3mf_files()
        +skipped_objects()
    }

