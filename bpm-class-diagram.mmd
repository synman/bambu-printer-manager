    %% ─── Relationships ──────────────────────────────────────────────

    %% BambuPrinter owns/uses
    BambuPrinter "1" *-- "1" BambuConfig : has
    BambuPrinter "1" *-- "1" BambuState : has
    BambuPrinter "1" *-- "1" ActiveJobInfo : has
    BambuPrinter ..> IoTFTPSClient : uses (FTP ops)
    BambuPrinter ..> ServiceState : uses

    %% BambuConfig composes
    BambuConfig "1" *-- "1" PrinterCapabilities : has
    BambuConfig ..> PrinterModel : uses
    BambuConfig ..> PrinterSeries : uses

    %% BambuState composes
    BambuState "1" *-- "1" BambuClimate : has
    BambuState "1" *-- "1" NozzleCharacteristics : active_nozzle
    BambuState "1" *-- "*" AMSUnitState : ams_units
    BambuState "1" *-- "*" ExtruderState : extruders
    BambuState "1" *-- "*" BambuSpool : spools
    BambuState ..> ActiveTool : uses
    BambuState ..> TrayState : uses

    %% ExtruderState composes
    ExtruderState "1" *-- "1" NozzleCharacteristics : nozzle
    ExtruderState ..> ExtruderInfoState : uses
    ExtruderState ..> ExtruderStatus : uses
    ExtruderState ..> TrayState : uses

    %% AMSUnitState uses
    AMSUnitState ..> AMSModel : uses
    AMSUnitState ..> AMSHeatingState : uses
    AMSUnitState ..> AMSDrySubStatus : uses
    AMSUnitState ..> ActiveTool : assigned_to_extruder

    %% NozzleCharacteristics uses
    NozzleCharacteristics ..> NozzleType : uses
    NozzleCharacteristics ..> NozzleFlowType : uses

    %% BambuClimate uses
    BambuClimate ..> AirConditioningMode : uses

    %% ActiveJobInfo composes
    ActiveJobInfo "1" *-- "0..1" ProjectInfo : project_info
    ActiveJobInfo ..> PlateType : uses

    %% FTP hierarchy
    ImplicitTLS --|> FtpListItem : produces
    IoTFTPSClient ..> FtpListItem : produces
    IoTFTPSClient ..> ImplicitTLS : uses internally

    %% AMSModel → AMSSeries
    AMSModel ..> AMSSeries : classified by
    PrinterModel ..> PrinterSeries : classified by
